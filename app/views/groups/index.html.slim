.container.mt-3
  .row.justify-content-between
    = render 'books/title', user: @user, new_book: @new_book
    .col-md-8.offset-md-1
      h2 Groups
      table.table.table-borderless
        thead.border-top
          tr.border-2.border-top-0.border-end-0.border-start-0
            th
            th.px-3.fw-bold グループ名
            th.px-3.fw-bold 紹介文
            th.px-3.fw-bold メンバー数
            th
        tbody
          - @groups.each do |group|
            tr.border-top
              td.py-3
                = image_tag group.get_group_image(80,80)
              td.p-3
                = link_to group.name, group_path(group), class: "link-underline link-underline-opacity-0 link-underline-opacity-100-hover"
              td.p-3
                = group.introduction
              td.p-3
                = group.members.count
              td.p-3
                - if group.owner == Current.user
                  = link_to "Edit", edit_group_path(group), class: "btn button--signup text-white rounded-1 px-2 py-1"