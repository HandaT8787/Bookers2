<div class="container mt-3">
  <div class="d-flex justify-content-center">
    <div class="col-md-6 col-lg-5">
      <h2>Event Mail</h2>
      <%= form_with url: send_mail_group_path(@group), method: :post, data: { turbo: false } do %>
        <div class="mb-3">
          <%= label_tag :subject, "Title", class: "mb-2" %>
          <%= text_field_tag :subject, nil, class: "form-control rounded-1" %>
        </div>
        <div class="mb-3">
          <%= label_tag :body, "Content", class: "mb-2" %>
          <%= text_area_tag :body, nil, class: "form-control rounded-1" %>
        </div>
        <div class="d-flex justify-content-end">
          <%= submit_tag "送信", class: "btn btn-signup text-white " %>
        </div>
      <% end %>
    </div>
  </div>
</div>