<div class="container mt-3">
  <div class="row justify-content-between">
    <%= render 'books/title', user: @user, new_book: @new_book %>

    <div class="col-md-8 offset-md-1">
      <h2>Group Detail</h2>
      <table class="table table-borderless">
        <thead class="border-top">
          <tr class="border-2 border-top-0 border-end-0 border-start-0">
            <th class="p-3"></th>
            <th class="p-3 fw-bold">グループ名</th>
            <th class="p-3 fw-bold">紹介文</th>
            <th class="p-3 fw-bold">メンバー</th>
            <th class="p-3"></th>
            <th class="p-3"></th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="p-3"><%= image_tag @group.get_group_image(80,80) %></td>
            <td class="p-3"><%= @group.name %></td>
            <td class="p-3"><%= @group.introduction %></td>
            <td class="p-3">
              <% @group.members.each do |member| %>
                <div><%= member.name %></div>
              <% end %>
            </td>
            <td class="p-3">
              <% if @group.owner == Current.user %>
                <%= link_to "Edit", edit_group_path(@group), class: "btn btn-signup text-white rounded-1" %>
              <% elsif @group.members.include?(Current.user) %>
                <%= link_to "Leave this group", group_group_user_path(@group), data: { turbo_method: :delete }, class: "btn btn-danger" %>
              <% else %>
                <%= link_to "Join this group", group_group_user_path(@group), data: { turbo_method: :post }, class: "btn btn-signup text-white rounded-1" %>
              <% end %>
            </td>
            <td class="p-3">
              <% if @group.owner == Current.user %>
                <%= link_to "Notice an Event", new_mail_group_path(@group), class: "btn btn-login text-white rounded-1" %>
              <% end %>
            </td>
          </tr>
        </tbody>
      </table>

      <% if @group.owner == Current.user %>
        <h2 class="mt-3">Transfer Owner</h2>
          <%= form_with url: transfer_ownership_group_path(@group), method: :patch do %>
            <%= select_tag :new_owner_id,
                  options_for_select(@group.members.where.not(id: @group.owner.id).map { |m| [m.name, m.id] }),
                  class: "form-control w-auto mb-2" %>
            <%= submit_tag "譲渡", data: { turbo_confirm: "本当に譲渡しますか？"} %>
          <% end %>
      <% end %>
    </div>
  </div>
</div>