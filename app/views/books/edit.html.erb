<h2>Editing Book</h2>
<%= form_with model: @book, url: book_path do |f| %>
  <% if @book.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@book.errors.count, "error") %> prohibited this obj from being saved:</h2>
      <ul>
        <% @book.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :title %>
    <%= f.text_field :title %>
  </div>
  <div class="field">
    <%= f.label :body, "Opinion" %>
    <%= f.text_area :body %>
  </div>
  <div class="actions">
    <%= f.submit "Update Book" %>
  </div>
  <div class="edit-button">
    <%= link_to "Show", book_path(@book.id) %>
    <span>|</span>
    <%= link_to "Back", books_path %>
  </div>
<% end %>