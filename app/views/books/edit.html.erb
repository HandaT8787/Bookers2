<div class="container mt-3 col-5">
  <div class="row">
    <h2 class="fs-1">Editing Book</h2>
      <% if @book.errors.any? %>
        <div id="error_explanation">
          <h2><%= pluralize(@book.errors.count, "error") %> prohibited this obj from being saved:</h2>
          <ul>
            <% @book.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
      <%= form_with model: @book, url: book_path do |f| %>
        <%= f.label :title, class: "mb-2"  %><br>
        <%= f.text_field :title, class: "border-1 border-secondary-subtle rounded-1 px-2 py-1 w-100 form-control" %><br>
        <%= f.label :body, "Opinion", class: "mb-2" %><br>
        <%= f.text_area :body, class: "border-1 border-secondary-subtle rounded-1 px-2 py-1 w-100 form-control mb-3" %>
        <%= f.submit "Update Book", class: "btn btn-signup text-white rounded-1 fs-6 mb-3" %><br>
        <%= link_to "Show", book_path(@book.id), class: "link-underline link-underline-opacity-0 link-underline-opacity-100-hover" %>
        <span>|</span>
        <%= link_to "Back", books_path, class: "link-underline link-underline-opacity-0 link-underline-opacity-100-hover" %>
      <% end %>
  </div>
</div>