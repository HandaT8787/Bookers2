<tbody id="books_list">
  <% books.each do |book| %>
    <tr class="border-top">
      <td class="p-2 pe-3" style="width: 1%;">
        <%= link_to user_path(book.user) do %>
          <%= image_tag book.user.get_profile_image(80,80) %>
        <% end %>
      </td>
      <td class="p-2 px-3"><%= link_to book.title, book_path(book.id), class: "link-underline link-underline-opacity-0 link-underline-opacity-100-hover" %></td>
      <td class="p-2 px-3"><%= book.body %></td>
      <td class="p-2 px-3">
        <% if book.tag %>
          <%= link_to book.tag.name, search_path(search_type: "tag_name", keyword: book.tag.name, match_type: "exact"), class: "link-underline link-underline-opacity-0 link-underline-opacity-100-hover" %>
        <% end %>
      </td>
      <%= render 'favorites/favorite', book: book %>
      <td class="p-2 px-3">
        コメント数: <%= book.book_comments.count %>
      </td>
      <td class="p-2 px-3">
        閲覧数: <%= book.views.count %>
      </td>
      <td class="p-2 px-3">
        <div class="show_raty"
            data-score="<%= book.score %>"
            data-star-on="<%= asset_path('raty/star-on.png') %>"
            data-star-off="<%= asset_path('raty/star-off.png') %>"
            data-star-half="<%= asset_path('raty/star-half.png') %>">
        </div>
      </td>
    </tr>
  <% end %>
</tbody>