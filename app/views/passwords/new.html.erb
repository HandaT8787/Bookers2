<div class="mt-3">
  <h2>Forgot your password?</h2>

  <%= tag.div(flash[:alert], style: "color:red") if flash[:alert] %>

  <%= form_with url: passwords_path do |form| %>
    <%= form.label :email, class: "mb-2" %><br>
    <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address] %><br>
    <%= form.submit "Send me reset password instructions" %>
  <% end %>
  <%= link_to "Log in", new_session_path, class: "link-underline link-underline-opacity-0 link-underline-opacity-100-hover" %>
  <br>
  <%= link_to "Sign up", new_user_path, class: "link-underline link-underline-opacity-0 link-underline-opacity-100-hover" %>
</div>