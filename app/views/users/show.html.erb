<div>
  <%= tag.div(flash[:alert]) if flash[:alert] %>
  <%= tag.div(flash[:notice]) if flash[:notice] %>
  <div>
    <div>
      <h2>User info</h2>
      <%= image_tag @user.get_profile_image(100,100) %>
      <p>name<%= @user.name %></p>
      <p>introduction<%= @user.introduction %></p>
      <p>
        <% if @user == Current.user %>
          <%= link_to edit_user_path(Current.user) do %>
            <i class="fa-solid fa-user-gear"></i>
          <% end %>
        <% else %>
          <%= link_to user_path(Current.user) do %>
            <i class="fa-solid fa-user-gear"></i>
          <% end %>
        <% end %>
      </p>
    </div>
    <div>
      <h2>New book</h2>
      <%= form_with model: @book, url: books_path do |f| %>
        <div class="field">
          <%= f.label :title %><br>
          <%= f.text_field :title %>
        </div>
        <div class="field">
          <%= f.label :body, "Opinion" %><br>
          <%= f.text_area :body %>
        </div>
        <div class="actions">
          <%= f.submit "Create Book" %>
        </div>
      <% end %>
    </div>
  </div>
  <div>
    <h2>Books</h2>
      <table>
        <thead>
          <tr>
            <th></th>
            <th>Title</th>
            <th>Opinion</th>
          </tr>
        </thead>
        <tbody>
          <% @books.each do |book| %>
            <tr>
              <td>
                <%= link_to user_path(book.user) do %>
                  <%= image_tag book.user.get_profile_image(100,100) %>
                <% end %>
              </td>
              <td><%= link_to book.title, book_path(book.id) %></td>
              <td><%= book.body %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
  </div>
</div>