<%= tag.div(flash[:alert]) if flash[:alert] %>
<%= tag.div(flash[:notice]) if flash[:notice] %>

<div class="container mt-3">
  <div class="row justify-content-between">
    <%= render 'books/title', user: @user, new_book: @new_book %>

    <div class="col-md-8 offset-md-1">
      <h2>Books</h2>
      <table class="table table-hover table-borderless">
        <thead class="border-top">
          <tr class=" border-2 border-top-0 border-end-0 border-start-0">
            <th></th>
            <th class="fw-bold">Title</th>
            <th class="fw-bold">Opinion</th>
            <th class="fw-bold">Tag</th>
            <th></th>
            <th></th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @books.each do |book| %>
            <tr>
              <td class="p-2 border-top">
                <%= link_to user_path(book.user) do %>
                  <%= image_tag book.user.get_profile_image(80,80) %>
                <% end %>
              </td>
              <td class="border-top"><%= link_to book.title, book_path(book.id), class: "link-underline link-underline-opacity-0 link-underline-opacity-100-hover" %></td>
              <td class="border-top"><%= book.body %></td>
              <td class="border-top">
                <% if book.tag %>
                  <%= link_to book.tag.name, search_path(search_type: "tag_name", keyword: book.tag.name, match_type: "exact"), class: "link-underline link-underline-opacity-0 link-underline-opacity-100-hover" %>
                <% end %>
              </td>
              <%= render 'favorites/favorite', book: book %>
              <td class="border-top">コメント数: <%= book.book_comments.count %></td>
              <td>
                <div class="show_raty"
                  data-score="<%= book.score %>"
                  data-star-on="<%= asset_path('raty/star-on.png') %>"
                  data-star-off="<%= asset_path('raty/star-off.png') %>"
                  data-star-half="<%= asset_path('raty/star-half.png') %>">
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <h2>7日間分の投稿数</h2>
      <table class="table table-bordered">
        <thead>
          <tr>
            <% @daily_counts.each do |date, count| %>
              <th>
                <% days_ago = Date.current - date %>
                <%= days_ago.zero? ? "今日" : "#{days_ago.to_i}日前" %>
              </th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <tr>
            <% @daily_counts.each do |date, count| %>
              <td><%= count %></td>
            <% end %>
          </tr>
        </tbody>
      </table>

      <canvas id="dailyCountsChart" width="600" height="300"></canvas>
      <script>
        document.addEventListener('turbo:load', function(){
          const canvas = document.getElementById('dailyCountsChart');
          if (!canvas) return;
          if (typeof Chart === 'undefined') return;

          const labels = <%= raw @daily_counts.map { |date, count|
            days_ago = Date.current - date
            days_ago.zero? ? "今日" : "#{days_ago.to_i}日前"
          }.to_json %>;
          const data = <%= raw @daily_counts.map { |date, count| count }.to_json %>;
          
          const existingChart = Chart.getChart(canvas);
          if (existingChart){
            existingChart.destroy();
          }

          const ctx = document.getElementById('dailyCountsChart').getContext('2d');
          new Chart(ctx, {
            type: 'line',
            data: {
              labels: labels,
              datasets: [{
                label: '投稿した本の数',
                data: data,
                borderColor: 'rgba(0, 0, 255, 1)',
                backgroundColor: 'rgba(255, 255, 255, 0)',
                tension: 0.3,
                fill: true
              }]
            },
            options: {
              plugins: {
                title: {
                  display: true,
                  text: '7日間の投稿数の比較',
                  font: { size: 12 }
                },
                legend: {
                  labels: { font: { size: 12 } }
                }
              },
              scales: {
                y: {
                  beginAtZero: true,
                  suggestedMax: 10,
                  ticks: {
                    stepSize: 1
                  }
                }
              }
            }
          });
        });
      </script>
      <%= turbo_frame_tag "selected_date_result" do %>
        <%= form_with url: user_path(@user), method: :get, data: { turbo_stream: true }, class: "d-flex align-items-center gap-2 mt-3" do |f| %>
          <%= f.date_field :date, value: params[:date], class: "form-control", style: "max-width: 200px;" %>
          <%= f.submit "検索", class: "btn btn-primary" %>
        <% end %>
        <%= render "selected_date_result" %>
      <% end %>
    </div>
  </div>
</div>