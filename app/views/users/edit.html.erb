<div class="container mt-3 col-7">
  <div class="row">
    <h2>User info</h2>
    <% if @user.errors.any? %>
      <div id="error_explanation">
        <h2><%= pluralize(@user.errors.count, "error") %> prohibited this obj from being saved:</h2>
        <ul>
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    <%= form_with model: @user do |f| %>
      <%= f.label :name, class: "mb-2" %><br>
      <%= f.text_field :name, class: "border-1 border-secondary-subtle rounded-1 px-2 py-1 w-100 form-control" %><br>
      <%= f.label :image, class: "mb-2"  %><br>
      <%= f.file_field :profile_image, placeholder: "プロフィール画像", accept: "image/*", class: "mb-3" %><br>
      <%= f.label :introduction, class: "mb-2"  %><br>
      <%= f.text_area :introduction, class: "border-1 border-secondary-subtle rounded-1 px-2 py-1 w-100 form-control" %><br>
      <%= f.submit "Update User", class: "btn btn-secondary fs-6 rounded-1" %>
    <% end %>
  </div>
</div>