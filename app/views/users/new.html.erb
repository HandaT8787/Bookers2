<div class="container p-0">
  <h2 class="mt-3">Sign up</h2>

  <%= form_with model: @user, url: users_path do |f| %>
    <%= render 'layouts/errors', obj: @user %>

    <div>
      <%= f.label :name, class: "mb-2" %><br>
      <%= f.text_field :name, autofocus: true %>
    </div>

    <div>
      <%= f.label :email_address, "Email", class: "mb-2" %><br>
      <%= f.email_field :email_address %>
    </div>

    <div>
      <%= f.label :password, class: "mb-2" %><span class="p-text fst-italic"> (6 characters minimum)</span><br>
      <%= f.password_field :password %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "mb-2" %><br>
      <%= f.password_field :password_confirmation %>
    </div>

    <div>
      <%= f.submit "Sign up", class: "btn btn-success btn-signup rounded-1 px-2" %>
    </div>
  <% end %>

  <%= link_to "Log in", new_session_path, class: "link-underline link-underline-opacity-0 link-underline-opacity-100-hover" %>
</div>