<div class="mt-3">
  <h2><%= action_name == "following" ? "Follow Users" : "Follower Users" %></h2>
  <table class="table table-borderless">
    <thead class="border-top">
      <tr class="border-2 border-top-0 border-end-0 border-start-0">
        <th>image</th>
        <th>name</th>
        <th></th>
        <th></th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td><%= image_tag user.get_profile_image(30,30) %></td>
          <td><%= user.name %></td>
          <td>フォロー数: <%= user.following.count %></td>
          <td>フォロワー数: <%= user.followers.count %></td>
          <td><%= link_to "Show", user_path(user.id), class: "link-underline link-underline-opacity-0 link-underline-opacity-100-hover" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>